# Supabase — https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Client (browser + server user sessions) — publishable key (recommended)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy JWT anon key (optional fallback if you still use it)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server only — secret key for admin script + RPC routes. NEVER use NEXT_PUBLIC_
# Copy from Dashboard → API → Secret keys (starts with sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy name (optional alias)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Optional: for `npm run fix-auth-trigger` (Dashboard → Connect → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@...pooler.supabase.com:5432/postgres
